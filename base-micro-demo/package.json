{
  "name": "qiankun-demo-spa",
  "private": true,
  "scripts": {
    "dev": "concurrently -n main,first,second -c blue,green,magenta \"pnpm -C spa-main dev\" \"pnpm -C micro-first dev\" \"pnpm -C micro-second dev\""
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "pnpm": {
    "overrides": {
      "@qiankunjs/loader": "file:../qiankun/packages/loader",
      "@qiankunjs/sandbox": "file:../qiankun/packages/sandbox",
      "@qiankunjs/shared": "file:../qiankun/packages/shared"
    }
  }
}
